{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": true,
        "indentStyle": "space",
        "indentWidth": 2,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "arrowParentheses": "asNeeded",
            "bracketSpacing": true,
            "jsxQuoteStyle": "double",
            "quoteProperties": "asNeeded",
            "semicolons": "always",
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "bracketSameLine": false
        },
        "parser": {
            "unsafeParameterDecoratorsEnabled": false
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended"
        }
    },
    "overrides": [
        {
            "includes": [
                "*.json"
            ],
            "formatter": {
                "indentWidth": 2
            }
        },
        {
            "includes": [
                "package.json"
            ],
            "formatter": {
                "indentWidth": 2
            }
        }
    ]
}